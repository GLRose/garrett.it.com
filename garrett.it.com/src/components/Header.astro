---
import { siteConfig } from '../config/site';
---

<header class="fixed top-0 inset-x-0 z-50 border-b border-zinc-800/60 bg-zinc-950/80 backdrop-blur-sm">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="font-semibold text-zinc-100 hover:text-sky-400 transition-colors">
      {siteConfig.name}
    </a>

    <nav class="flex items-center gap-8 text-sm text-zinc-400">
      <a href="#services" class="hover:text-zinc-100 transition-colors">Services</a>
      <a href="#about" class="hover:text-zinc-100 transition-colors">About</a>
      <a href="#contact" class="hover:text-sky-400 transition-colors text-sky-400 font-medium">
        Contact
      </a>
    </nav>
  </div>
</header>
