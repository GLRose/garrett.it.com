---
import { siteConfig } from '../config/site';
import ServiceCard from './ServiceCard.astro';
---

<section id="services" class="py-24 bg-zinc-900/40">
  <div class="max-w-6xl mx-auto px-6">
    <div class="mb-14">
      <p class="text-sky-400 text-xs font-mono uppercase tracking-widest mb-3">What I do</p>
      <h2 class="text-3xl md:text-4xl font-bold text-zinc-100">Services</h2>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {siteConfig.services.map((service) => (
        <ServiceCard {...service} />
      ))}
    </div>
  </div>
</section>
