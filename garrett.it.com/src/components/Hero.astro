---
import { siteConfig } from '../config/site';

const { eyebrow, headline, tagline, cta } = siteConfig.hero;
---

<section class="min-h-screen flex items-center justify-center px-6 pt-16">
  <div class="text-center max-w-3xl">
    <p class="text-sky-400 text-xs font-mono uppercase tracking-widest mb-6">
      {eyebrow}
    </p>
    <h1 class="text-5xl md:text-7xl font-bold text-zinc-100 mb-6 tracking-tight">
      {headline}
    </h1>
    <p class="text-lg md:text-xl text-zinc-400 leading-relaxed mb-10">
      {tagline}
    </p>
    <a
      href="#contact"
      class="inline-block bg-sky-400 hover:bg-sky-300 text-zinc-950 font-semibold px-8 py-3 rounded-lg transition-colors"
    >
      {cta}
    </a>
  </div>
</section>
