---
import { siteConfig } from '../config/site';

const { headline, body } = siteConfig.about;
---

<section id="about" class="py-24">
  <div class="max-w-3xl mx-auto px-6">
    <p class="text-sky-400 text-xs font-mono uppercase tracking-widest mb-3">About</p>
    <h2 class="text-3xl md:text-4xl font-bold text-zinc-100 mb-6 leading-snug">
      {headline}
    </h2>
    <p class="text-zinc-400 text-lg leading-relaxed">
      {body}
    </p>
  </div>
</section>
